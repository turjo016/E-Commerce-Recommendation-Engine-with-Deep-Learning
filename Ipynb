df = pd.read_parquet("/content/test.parquet")

print(df.head())

df = df[
    [
        "user_id",
        "product_id",
        "event_type",
        "brand",
        "price",
        "cat_0",
        "cat_1"
    ]
]

# Brand
if str(df["brand"].dtype) == "category":
    df["brand"] = df["brand"].cat.add_categories(["unknown"])
df["brand"] = df["brand"].fillna("unknown").astype(str)

# Category 0
if str(df["cat_0"].dtype) == "category":
    df["cat_0"] = df["cat_0"].cat.add_categories(["unknown"])
df["cat_0"] = df["cat_0"].fillna("unknown").astype(str)

# Category 1
if str(df["cat_1"].dtype) == "category":
    df["cat_1"] = df["cat_1"].cat.add_categories(["unknown"])
df["cat_1"] = df["cat_1"].fillna("unknown").astype(str)

# Price
df["price"] = pd.to_numeric(df["price"], errors="coerce")
df["price"] = df["price"].fillna(df["price"].median())

print(df.isnull().sum())

interaction = {
    "view": 1,
    "cart": 2,
    "purchase": 3
}

df["interaction"] = (
    df["event_type"]
      .map(interaction)
      .fillna(1)
      .astype(np.float32)
)

df["user_id"] = df["user_id"].astype(str)
df["product_id"] = df["product_id"].astype(str)

df = (
    df.sort_values("interaction")
      .drop_duplicates(
          ["user_id", "product_id"],
          keep="last"
      )
)

