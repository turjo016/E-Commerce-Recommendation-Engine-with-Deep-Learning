# User IDs
user_ids = df["user_id"].astype(str).unique()

# Product IDs
product_ids = df["product_id"].astype(str).unique()

print("Total Users:", len(user_ids))
print("Total Products:", len(product_ids))

embedding_dim = 64

user_model = tf.keras.Sequential([
    tf.keras.layers.StringLookup(
        vocabulary=user_ids,
        mask_token=None
    ),
    tf.keras.layers.Embedding(
        input_dim=len(user_ids) + 1,
        output_dim=embedding_dim
    )
])

product_model = tf.keras.Sequential([
    tf.keras.layers.StringLookup(
        vocabulary=product_ids,
        mask_token=None
    ),
    tf.keras.layers.Embedding(
        input_dim=len(product_ids) + 1,
        output_dim=embedding_dim
    )
])

sample_user = tf.constant(["100"])
print(user_model(sample_user))

sample_product = tf.constant(["100098522"])
print(product_model(sample_product))

candidate_dataset = (
    tf.data.Dataset
      .from_tensor_slices(product_ids)
      .batch(512)
      .map(product_model)
)

for embedding in candidate_dataset.take(1):
    print(embedding.shape)

candidate_dataset = (
    tf.data.Dataset
    .from_tensor_slices(product_ids)
    .batch(512)
    .map(product_model)
)

retrieval_task = tfrs.tasks.Retrieval(
    metrics=tfrs.metrics.FactorizedTopK(
        candidates=candidate_dataset
    )
)

class EcommerceModel(tfrs.models.Model):

    def __init__(self, user_model, product_model):
        super().__init__()

        self.user_model = user_model
        self.product_model = product_model

        self.task = tfrs.tasks.Retrieval(
            metrics=tfrs.metrics.FactorizedTopK(
                candidates=candidate_dataset
            )
        )

    def compute_loss(self, features, training=False):

        user_embeddings = self.user_model(features["user_id"])

        product_embeddings = self.product_model(features["product_id"])

        return self.task(
            user_embeddings,
            product_embeddings
        )

model = EcommerceModel(
    user_model=user_model,
    product_model=product_model
)

model.compile(
    optimizer=tf.keras.optimizers.Adagrad(
        learning_rate=0.1
    )
)

dummy_batch = next(iter(train))

loss = model.compute_loss(dummy_batch)

print("Initial Loss:", loss.numpy())

history = model.fit(
    train,
    validation_data=test,
    epochs=2
)


